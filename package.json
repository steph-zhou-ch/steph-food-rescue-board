{
  "name": "@charliehealth/app-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Greenfield project monorepo — spec-driven swarm methodology + NestJS hexagonal layout.",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "dev": "pnpm --filter @app/web dev & pnpm --filter @app/api dev",
    "dev:web": "pnpm --filter @app/web dev",
    "dev:api": "pnpm --filter @app/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "codegen": "graphql-codegen --config codegen.ts",
    "check": "pnpm typecheck && pnpm test",
    "req-lint": "tsx tools/req-lint/src/lint.ts",
    "req-coverage": "tsx tools/req-coverage/src/coverage.ts",
    "compose-prompts": "tsx tools/prompt-composer/src/compose.ts",
    "validate-prompt-composition": "tsx tools/prompt-composer/src/compose.ts --validate-only",
    "check-track-meta-paths": "tsx tools/check-track-meta-paths/src/check.ts",
    "gate-check": "./orchestration/gates/gate-check.sh",
    "auth-doctor": "./tools/scion-auth-doctor/check.sh",
    "captain-status": "./tools/captain-status/status.sh",
    "captain-notify": "./tools/captain-notify/notify.sh",
    "manager-watchdog": "./tools/manager-watchdog/watch.sh"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.3",
    "@graphql-codegen/typescript": "4.1.1",
    "@graphql-codegen/typescript-resolvers": "4.4.0",
    "@types/node": "20.14.10",
    "@typescript-eslint/eslint-plugin": "8.8.1",
    "@typescript-eslint/parser": "8.8.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.31.0",
    "graphql": "16.9.0",
    "node-notifier": "10.0.1",
    "prettier": "3.3.3",
    "tsx": "4.19.2",
    "typescript": "5.5.3",
    "vitest": "2.1.4"
  }
}
